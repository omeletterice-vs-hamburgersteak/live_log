<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <title>ライブ参戦記録アプリ</title>
  <!-- ここにCSSやJSのリンクを追加 -->
</head>
<body>
  <div class="container mx-auto p-4 bg-[#FFF0F5]">
    <h1 class="text-3xl text-center font-kaisei text-[#663300] mb-4">推し</h1>
    <p style="color: green"><%= notice %></p>

    <%= render @favorite %>

    <% @favorite.artists.each do |artist| %>
      <%= link_to artist.name, artist_path(artist), class: "text-blue-500 underline" %>
    <% end %>

    <h2 class="text-xl font-bold mt-6 mb-2">最近の参戦イベント</h2>
    <% if @live_events.any? %>
      <ul class="space-y-2">
        <% @live_events.each do |live| %>
          <li class="border rounded p-2 hover:bg-gray-50">
            <%= link_to live_event_path(live), class: "block" do %>
              <span class="font-semibold">
                <%= live.date %>
              </span>
              <span class="ml-2">
                <%= live.title %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-500">まだ出演ライブはありません。</p>
    <% end %>
    <br>

    <div>
      <%= link_to "推しを編集する", edit_favorite_path(@favorite), class: "bg-[#6a5acd] hover:bg-[#7b68ee] text-white font-bold py-2 px-4 rounded mt-1" %>
      <%= link_to "推し一覧に戻る", favorites_path, class: "inline-block bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 px-4 rounded mt-4" %>
      <br>
      <%= button_to "この推しを削除する", @favorite, method: :delete %>
    </div>
</body>
</html>