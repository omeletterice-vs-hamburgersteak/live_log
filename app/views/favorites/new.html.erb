<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <title>ライブ参戦記録アプリ</title>
  <!-- ここにCSSやJSのリンクを追加 -->
</head>
<body>
  <div class="container mx-auto p-4 bg-[#FFF0F5]">
    <h1 class="text-3xl text-center font-kaisei text-[#663300] mb-4">推し登録</h1>
    <% content_for :title, "推し登録" %>

    <%= render "form", favorite: @favorite %>

    <br>

    <div>
      <%= link_to "推し一覧に戻る", favorites_path, class: "bg-[#6a5acd] hover:bg-[#7b68ee] text-white font-bold py-2 px-4 rounded mt-1" %>
      <%= link_to "イベント一覧に戻る", live_events_path, class: "inline-block bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 px-4 rounded mt-4" %>
    </div>
  </div>
</body>
</html>