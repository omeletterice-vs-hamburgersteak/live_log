<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <title>ライブ参戦記録アプリ</title>
  <!-- ここにCSSやJSのリンクを追加 -->
</head>
<body>
  <div class="container mx-auto p-4 bg-[#FFF0F5]">
    <h1 class="text-3xl text-center font-kaisei text-[#663300] mb-4">私の推し</h1>
    <p style="color: green"><%= notice %></p>

    <% content_for :title, "推し一覧" %>

    <div id="favorites">
      <% @favorites.each do |favorite| %>
        <%= render favorite %>
        <br>
        <p>
          <%= link_to "推しの詳細を見る", favorite, class: "bg-[#6a5acd] hover:bg-[#7b68ee] text-white font-bold py-2 px-4 rounded mt-1" %>
        </p>
        <br>
        <p>
          -------
        </p>
      <% end %>
    </div>

    <div>
      <%= link_to "➕推しの追加", new_favorite_path, class: "bg-[#66cdaa] hover:bg-[#3cb371] text-white font-bold py-2 px-4 rounded mt-1" %>
      <%= link_to "イベント一覧に戻る", live_events_path, class: "inline-block bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 px-4 rounded mt-4" %>
    </div>
</body>
</html>