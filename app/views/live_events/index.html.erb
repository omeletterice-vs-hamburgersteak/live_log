<div class="max-w-6xl mx-auto p-6">
  <h1 class="text-3xl font-kaisei text-center text-pink-600 mb-8">
    参戦したライブ・イベント一覧
  </h1>

  <!-- アーティストで絞り込み -->
  <div class="mb-6">
    <span id="artist-toggle" class="cursor-pointer font-bold text-pink-500 inline-flex items-center gap-1">
      出演者で絞り込み 🔻
    </span>

    <div id="artist-filter" class="hidden mt-2 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
      <% if params[:artist_id].present? %>
        <%= link_to "絞り込み解除",
            live_events_path,
            class: "bg-gray-200 hover:bg-gray-300 text-gray-800 text-sm font-medium px-3 py-1 rounded-full text-center transition" %>
      <% end %>

      <% @artists.each do |artist| %>
        <%= link_to artist.name,
            live_events_path(artist_id: artist.id),
            class: "bg-pink-100 hover:bg-pink-200 text-pink-700 font-medium text-sm px-3 py-1 rounded-full text-center transition" %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @live_events.order(date: :desc).each do |event| %>
      <div class="bg-white rounded-2xl shadow-md p-4 hover:shadow-xl transition">
        <h2 class="text-lg font-bold text-gray-800 mb-2">
          <%= link_to event.title, live_event_path(event), class: "hover:text-pink-500" %>
        </h2>

        <p class="text-gray-600 text-sm mb-1">
          📅 <%= event.date.strftime("%Y/%m/%d") %>
        </p>
        <p class="text-gray-600 text-sm mb-1">
          🎤 出演者: <%= event.artists.map(&:name).join(", ") %>
        </p>
        <p class="text-gray-600 text-sm mb-3">
          🏟 会場: <%= event.venue %>
        </p>

        <div class="flex gap-2">
          <%= link_to "編集", edit_live_event_path(event),
              class: "bg-green-500 hover:bg-green-600 text-white font-bold py-1 px-3 rounded" %>
          <%= link_to "削除", live_event_path(event),
              data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
              class: "bg-red-500 hover:bg-red-600 text-white font-bold py-1 px-3 rounded" %>
        </div>
      </div>
    <% end %>
  </div>
</div>