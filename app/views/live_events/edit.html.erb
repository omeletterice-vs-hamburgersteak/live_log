<div class="max-w-3xl mx-auto p-6">
  <h1 class="text-3xl font-kaisei text-center text-pink-600 mb-8">
    ライブ・イベントの編集
  </h1>

  <div class="bg-white rounded-2xl shadow-md p-6 space-y-6">
    <%= form_with model: @live_event do |form| %>
      <div class="flex flex-col gap-2">
        <%= form.label :title, "ライブ名", class: "font-semibold" %>
        <%= form.text_field :title, class: "w-full p-2 border border-gray-300 rounded" %>
      </div>

      <div class="flex flex-col gap-2">
        <%= form.label :date, "日付", class: "font-semibold" %>
        <%= form.date_select :date, {}, { class: "w-full border border-gray-300 rounded p-2 bg-white" } %>
      </div>

      <!-- 会場 -->
      <div class="flex flex-col gap-2">
        <%= form.label :venue, "会場", class: "font-semibold" %>
        <%= form.text_field :venue, class: "w-full border border-gray-300 rounded p-2 bg-white" %>
      </div>

      <div>
        <p class="font-bold mb-2">出演者</p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2 max-h-60 overflow-y-auto">
          <% Artist.order(:name).each do |artist| %>
            <label class="flex items-center gap-2 border rounded-full px-3 py-1 hover:bg-pink-50 cursor-pointer text-sm transition">
              <%= check_box_tag "live_event[artist_ids][]",
                    artist.id,
                    @live_event.artist_ids.include?(artist.id),
                    class: "accent-pink-500" %>
              <span><%= artist.name %></span>
            </label>
          <% end %>
        </div>
      </div>

      <!-- ボタン -->
      <div class="flex justify-center mt-4">
        <%= form.submit "更新",
            class: "bg-pink-500 hover:bg-pink-600 text-white font-bold py-2 px-6 rounded transition" %>
      </div>

    <% end %>
  </div>
</div>