<div class="max-w-3xl mx-auto p-6">
  <h1 class="text-3xl font-kaisei text-center text-pink-600 mb-8">
    ライブ・イベントを追加
  </h1>

  <div class="bg-white rounded-2xl shadow-md p-6 space-y-6">
    <%= form_with(model: @live_event, local: true) do |form| %>
      
      <div class="flex flex-col">
        <%= form.label :title, "ライブ・イベント名", class: "font-semibold mb-1" %>
        <%= form.text_field :title, class: "w-full p-2 border border-gray-300 rounded" %>
      </div>

      <div class="flex flex-col">
        <%= form.label :date, "日付", class: "font-semibold mb-1" %>
        <%= form.date_select :date, {}, { class: "bg-white border border-gray-300 rounded p-2" } %>
      </div>

      <div class="flex flex-col">
        <%= form.label :venue, "会場", class: "font-semibold mb-1" %>
        <%= form.text_field :venue, class: "border border-gray-300 rounded p-2" %>
      </div>

      <div class="flex flex-col">
        <label class="font-semibold mb-1">出演者（既存）</label>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          <%= form.collection_check_boxes :artist_ids, @artists, :id, :name do |b| %>
            <label class="flex items-center bg-gray-100 rounded-full px-3 py-1 hover:bg-gray-200 cursor-pointer text-sm">
              <%= b.check_box(class: "mr-2") %> <%= b.label %>
            </label>
          <% end %>
        </div>
      </div>

      <div class="flex flex-col">
        <%= form.label :new_artist_name, "新しい出演者を追加", class: "font-semibold mb-1" %>
        <%= form.text_field :new_artist_name, class: "w-full p-2 border border-gray-300 rounded" %>
      </div>

      <br>

      <div class="flex justify-center">
        <%= form.submit "登録", class: "bg-pink-500 hover:bg-pink-600 text-white font-bold py-2 px-6 rounded transition" %>
      </div>

    <% end %>
  </div>
</div>