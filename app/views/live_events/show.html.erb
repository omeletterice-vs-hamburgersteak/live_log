<div class="max-w-3xl mx-auto p-6">
  <!-- ライブタイトル -->
  <h1 class="text-3xl font-kaisei text-center text-pink-600 mb-8">
    <%= @live_event.title %>
  </h1>

  <!-- ライブ情報カード -->
  <div class="bg-white rounded-2xl shadow-md p-6 space-y-4">
    <!-- 開催日・会場 -->
    <p class="text-gray-700"><span class="font-semibold">開催日：</span> <%= @live_event.date.strftime("%Y/%m/%d") %></p>
    <p class="text-gray-700"><span class="font-semibold">会場：</span> <%= @live_event.venue %></p>

    <!-- 出演者 -->
    <% if @live_event.artists.any? %>
      <div>
        <span class="font-semibold text-gray-700">出演者：</span>
        <div class="flex flex-wrap gap-2 mt-1">
          <% @live_event.artists.each do |artist| %>
            <%= link_to artist.name,
                artist_path(artist),
                class: "bg-pink-100 hover:bg-pink-200 text-pink-700 font-medium text-sm px-3 py-1 rounded-full transition" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="flex gap-2 mt-4">
      <%= link_to "編集", edit_live_event_path(@live_event),
          class: "bg-pink-500 hover:bg-pink-600 text-white font-bold py-2 px-4 rounded transition" %>

      <%= link_to "削除", live_event_path(@live_event),
          data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
          class: "bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded transition" %>
    </div>
  </div>
</div>