<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <title>各イベントの詳細</title>

</head>
<body>
  <div class="container mx-auto p-4 bg-[#FFF0F5]">
    <h1 class="text-3xl text-center font-kaisei text-[#663300] mb-4"><%= @live_event.title %></h1>
    <p>開催日：
    <%= @live_event.date %></p>

    <p>会場：
    <%= @live_event.venue %></p>
    <br>
    <%= link_to "編集", edit_live_event_path(@live_event), class: "text-green-600 hover:underline mr-2" %>
    <%= link_to "イベント一覧に戻る", live_events_path, class: "inline-block bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 px-4 rounded mt-4" %>
  </div>
</body>
</html>