<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <title>ライブ参戦記録アプリ</title>

</head>
<body>
  <div class="container mx-auto p-4 bg-[#FFF0F5]">
    <h1 class="text-3xl text-center font-kaisei text-[#663300] mb-4">出演者一覧</h1>

    <div class="text-right">
    <%= link_to "➕出演者追加", new_artist_path, class: "bg-[#6a5acd] hover:bg-[#7b68ee] text-white font-bold py-2 px-4 rounded" %>
    </div>

    <ul>
      <% @artists.each do |artist| %>
        <li>
          <%= link_to artist.name, artist %>
        </li>
      <% end %>
    </ul>

  </div>
</body>
</html>