<!DOCTYPE html>
  <html lang="ja">
  <head>
    <meta charset="utf-8">
    <title>ライブ参戦記録アプリ</title>
    <!-- ここにCSSやJSのリンクを追加 -->
  </head>
  <body>
    <div class="container mx-auto p-4 bg-[#FFF0F5]">
    <h1 class="text-3xl text-center font-kaisei text-[#663300] mb-4">
      <%= @artist.name %>
    </h1>

    <h2 class="text-2xl font-kaisei text-[#663300]">出演ライブ</h2>

    <% if @artist.live_events.any? %>
      <ul>
        <% @artist.live_events.each do |event| %>
          <li>
            <%= link_to event.title, event %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>まだライブ登録はありません。</p>
    <% end %>

    <div>
      <%= link_to "一覧に戻る", live_events_path, class: "inline-block bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 px-4 rounded mt-4" %>
    </div>
  </body>
</html>