<div class="max-w-6xl mx-auto p-6">
  <h1 class="text-3xl font-kaisei text-center text-pink-600 mb-8">
    <%= @artist.name %> のイベント参戦歴🌟
  </h1>

  <div class="bg-white rounded-2xl shadow-md p-6 mb-6">
    <h3 class="text-xl font-bold text-gray-800 mb-4">
      ライブ・イベント情報
      <% current_direction = params[:direction] == "desc" ? "desc" : "asc" %>
      <% next_direction = current_direction == "asc" ? "desc" : "asc" %>
      <%= link_to "日付#{current_direction == 'asc' ? '↑' : '↓'}", artist_path(@artist, direction: next_direction), class: "text-sm text-pink-500 ml-2" %>
    </h3>

    <% sorted_events = @artist.live_events.order(date: params[:direction] == "desc" ? :desc : :asc) %>
    
    <% if sorted_events.any? %>
      <ul class="space-y-2">
        <% sorted_events.each do |event| %>
          <li class="border-b last:border-b-0 pb-2">
            <%= link_to event.title, event, class: "text-pink-500 hover:underline" %>
            <p class="text-gray-500 text-sm"><%= event.date.strftime("%Y/%m/%d") %></p>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-500">まだライブ登録はありません 💭</p>
    <% end %>
  </div>

  <div class="flex gap-2 justify-center">
    <%= link_to "編集する", edit_artist_path(@artist), class: "bg-pink-500 hover:bg-pink-600 text-white font-bold py-2 px-4 rounded" %>
    <%= button_to "削除する", @artist,
        method: :delete,
        data: {
          turbo_confirm: "本当に削除しますか？",
          testid: "artist-destroy"
        },
        class: "bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded" %>
  </div>
</div>