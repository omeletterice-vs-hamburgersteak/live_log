<div class="max-w-3xl mx-auto p-6">
  <div class="bg-white rounded-2xl shadow-md p-6 space-y-6">

    <%= form_with(model: artist) do |form| %>
      <% if artist.errors.any? %>
        <div class="text-red-600 bg-red-50 p-3 rounded">
          <h2 class="font-bold mb-2">
            <%= pluralize(artist.errors.count, "error") %> が保存を妨げました:
          </h2>
          <ul class="list-disc list-inside">
            <% artist.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex flex-col">
        <%= form.label :name, "名前", class: "font-semibold mb-1" %>
        <%= form.text_field :name, class: "w-full p-2 border border-gray-300 rounded" %>
      </div>

      <br>

      <div class="flex justify-center">
        <%= form.submit "更新",
            class: "bg-pink-500 hover:bg-pink-600 text-white font-bold py-2 px-6 rounded transition" %>
      </div>
    <% end %>
  </div>
</div>
