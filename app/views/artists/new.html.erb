<div class="max-w-3xl mx-auto p-6">
  <h1 class="text-3xl font-kaisei text-center text-pink-600 mb-8">
    出演者の追加
  </h1>

  <div class="bg-white rounded-2xl shadow-md p-6 space-y-6">
    <div class="flex flex-wrap gap-2">
      <% @artists.each do |artist| %>
        <%= link_to artist.name,
            live_events_path(artist_id: artist.id),
            class: "bg-pink-100 hover:bg-pink-200 text-pink-700 font-medium text-sm px-3 py-1 rounded-full text-center transition" %>
      <% end %>
    </div>

    <%= form_with model: @artist, local: true do |f| %>
      <div class="flex flex-col gap-2">
        <div class="flex flex-col">
          <%= f.label :name, "名前", class: "font-semibold mb-1" %>
          <%= f.text_field :name, class: "w-full p-2 border border-gray-300 rounded" %>
        </div>

        <div class="flex justify-center mt-4">
          <%= f.submit "保存", data: { testid: "artist-submit" },
              class: "bg-pink-500 hover:bg-pink-600 text-white font-bold py-2 px-6 rounded transition" %>
        </div>
      </div>
    <% end %>
  </div>
</div>