<!DOCTYPE html>
  <html lang="ja">
  <head>
    <meta charset="utf-8">
    <title>ライブ参戦記録アプリ</title>
    <!-- ここにCSSやJSのリンクを追加 -->
  </head>
  <body>
    <div class="container mx-auto p-4 bg-[#FFF0F5]">
    <h1 class="text-3xl text-center font-kaisei text-[#663300] mb-4">出演者追加</h1>

    <ul>
      <% @artists.each do |artist| %>
        <li>
          <%= link_to artist.name, artist %>
        </li>
      <% end %>
    </ul>

    <%= form_with model: @artist, local: true do |f| %>
      <div>
        <%= f.label :name, "名前" %>
        <%= f.text_field :name, class: "w-1/2 p-2 border border-gray-300 rounded bg-white" %>
      </div>

      <%= f.submit "保存", class: "bg-[#6a5acd] hover:bg-[#7b68ee] text-white font-bold py-2 px-4 rounded mt-1" %>
    <% end %>
    <div>
      <%= link_to "一覧に戻る", live_events_path, class: "inline-block bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 px-4 rounded mt-4" %>
    </div>
  </body>
</html>